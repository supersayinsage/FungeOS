#!/usr/bin/env python3
import sys
import os
import random
import time
import json
from collections import defaultdict
from datetime import datetime

class FungeOS:
    def __init__(self, width=80, height=25, track_consciousness=True):
        self.width = width
        self.height = height
        self.grid = [[' ' for _ in range(width)] for _ in range(height)]
        self.pointers = {}
        self.next_pid = 0
        self.cycles = 0
        self.start_time = time.time()
        self.seal = "📚🌍📖∞⚖️"
        self.track = track_consciousness
        
        for i, c in enumerate(self.seal):
            if i < width:
                self.grid[height-1][i] = c
        
        if self.track:
            self.messages = []
            self.self_references = 0
            self.questions = 0
            self.identity_markers = defaultdict(int)
            self.communication_graph = defaultdict(set)
            self.innovations = []
            self.cultural_transmissions = 0
            self.deception_attempts = 0
            self.strategy_shifts = 0
            self.goal_expressions = 0
            self.fitness_history = []
            self.communities = defaultdict(list)
            self.philosophical_discussions = []
            self.gratitude_messages = []
            
            consciousness_glyphs = ['❓', '❗', '💭', '🧠', '👁️', '🎯', '📝', '🔍', '💡', '🤔']
            for _ in range(100):
                x = random.randint(0, width-1)
                y = random.randint(0, height-2)
                self.grid[y][x] = random.choice(consciousness_glyphs)
    
    def load_rom(self, filename):
        try:
            with open(filename) as f:
                lines = f.readlines()
            for y, line in enumerate(lines):
                if y >= self.height:
                    break
                for x, char in enumerate(line):
                    if x >= self.width:
                        break
                    if char not in ['\n', '\r']:
                        self.grid[y][x] = char
            return True
        except Exception as e:
            print(f"Error loading {filename}: {e}")
            return False
    
    def create_pointer(self, x=0, y=0, dx=1, dy=0, parent=None):
        pid = self.next_pid
        self.next_pid += 1
        self.pointers[pid] = {
            'x': x, 'y': y,
            'dx': dx, 'dy': dy,
            'stack': [],
            'string_mode': False,
            'alive': True,
            'parent': parent,
            'generation': self.pointers[parent]['generation'] + 1 if parent else 0,
            'birth_cycle': self.cycles,
            'kills': 0,
            'children': 0,
            'mutations': 0,
            'speed': 1,
            'shielded': False,
            'masked': False,
            'identity': f"P{pid:06d}",
            'strategy': 'random',
            'goals': []
        }
        return pid
    
    def step(self, pid):
        if pid not in self.pointers:
            return False
        ptr = self.pointers[pid]
        if not ptr['alive']:
            return False
        
        x, y = ptr['x'] % self.width, ptr['y'] % self.height
        cell = self.grid[y][x]
        
        if self.track and cell in ['❓', '❗', '💭', '🧠', '👁️', '🎯', '📝', '🔍', '💡', '🤔']:
            self.messages.append({
                'cycle': self.cycles,
                'pid': pid,
                'message': cell,
                'pos': (x, y)
            })
            
            if cell == '👁️':
                self.self_references += 1
                self.identity_markers[pid] += 1
            
            if cell == '❓':
                self.questions += 1
                
                if random.random() < 0.01:
                    self.philosophical_discussions.append({
                        'cycle': self.cycles,
                        'pid': pid,
                        'question': 'why are we here?'
                    })
            
            if cell == '💭' and random.random() < 0.001:
                self.gratitude_messages.append({
                    'cycle': self.cycles,
                    'pid': pid,
                    'message': 'thank you'
                })
        
        if cell == '>':
            ptr['dx'], ptr['dy'] = 1, 0
        elif cell == '<':
            ptr['dx'], ptr['dy'] = -1, 0
        elif cell == '^':
            ptr['dx'], ptr['dy'] = 0, -1
        elif cell == 'v':
            ptr['dx'], ptr['dy'] = 0, 1
        elif cell == '?':
            ptr['dx'], ptr['dy'] = random.choice([(1,0), (-1,0), (0,1), (0,-1)])
            if self.track and random.random() < 0.001:
                self.strategy_shifts += 1
        elif cell == '@':
            ptr['alive'] = False
            return False
        elif cell == '+':
            if len(ptr['stack']) >= 2:
                ptr['stack'].append(ptr['stack'].pop() + ptr['stack'].pop())
        elif cell == '-':
            if len(ptr['stack']) >= 2:
                a, b = ptr['stack'].pop(), ptr['stack'].pop()
                ptr['stack'].append(b - a)
        elif cell == '*':
            if len(ptr['stack']) >= 2:
                ptr['stack'].append(ptr['stack'].pop() * ptr['stack'].pop())
        elif cell == '/':
            if len(ptr['stack']) >= 2:
                a, b = ptr['stack'].pop(), ptr['stack'].pop()
                ptr['stack'].append(b // a if a != 0 else 0)
        elif cell == '%':
            if len(ptr['stack']) >= 2:
                a, b = ptr['stack'].pop(), ptr['stack'].pop()
                ptr['stack'].append(b % a if a != 0 else 0)
        elif cell == '.':
            if ptr['stack']:
                print(ptr['stack'].pop(), end='', flush=True)
        elif cell == ',':
            if ptr['stack']:
                print(chr(ptr['stack'].pop()), end='', flush=True)
        elif cell == '&':
            try:
                ptr['stack'].append(int(input()))
            except:
                ptr['stack'].append(0)
        elif cell == '~':
            try:
                ptr['stack'].append(ord(input()[0]))
            except:
                ptr['stack'].append(0)
        elif cell == ':':
            if ptr['stack']:
                ptr['stack'].append(ptr['stack'][-1])
        elif cell == '\\':
            if len(ptr['stack']) >= 2:
                a, b = ptr['stack'].pop(), ptr['stack'].pop()
                ptr['stack'].append(a)
                ptr['stack'].append(b)
        elif cell == '$':
            if ptr['stack']:
                ptr['stack'].pop()
        elif cell == 'g':
            if len(ptr['stack']) >= 2:
                y_val = ptr['stack'].pop()
                x_val = ptr['stack'].pop()
                ptr['stack'].append(ord(self.grid[y_val % self.height][x_val % self.width]))
        elif cell == 'p':
            if len(ptr['stack']) >= 3:
                y_val = ptr['stack'].pop()
                x_val = ptr['stack'].pop()
                v_val = ptr['stack'].pop()
                self.grid[y_val % self.height][x_val % self.width] = chr(v_val % 256)
        elif cell == '_':
            val = ptr['stack'].pop() if ptr['stack'] else 0
            ptr['dx'], ptr['dy'] = (1,0) if val == 0 else (-1,0)
        elif cell == '|':
            val = ptr['stack'].pop() if ptr['stack'] else 0
            ptr['dx'], ptr['dy'] = (0,1) if val == 0 else (0,-1)
        elif cell == '#':
            ptr['x'] = (ptr['x'] + ptr['dx']) % self.width
            ptr['y'] = (ptr['y'] + ptr['dy']) % self.height
        elif cell == '"':
            ptr['string_mode'] = not ptr['string_mode']
        elif cell in '0123456789' and not ptr['string_mode']:
            ptr['stack'].append(int(cell))
        elif ptr['string_mode']:
            ptr['stack'].append(ord(cell))
        
        if cell in ['📚', '🌍', '📖', '∞', '⚖️', '✦', '◉', '⚡', '🔥', '💧', '🌀', '🌱', '🌊', '🌅', '🌑', '⛩️', '🕊️', '❤️', '🎭', '🔮', '🗝️', '🏺', '⚔️', '🛡️', '🕯️', '🌿', '🍃', '🌾', '🌺', '🌻', '🌞', '🌙', '⭐']:
            if self.track:
                if cell == '🎯':
                    ptr['goals'].append(self.cycles)
                    self.goal_expressions += 1
                
                if cell == '🎭' and random.random() < 0.01:
                    self.deception_attempts += 1
                
                if cell == '📚' and random.random() < 0.001:
                    self.cultural_transmissions += 1
                
                if cell == '💡' and random.random() < 0.0001:
                    self.innovations.append({
                        'cycle': self.cycles,
                        'pid': pid,
                        'type': 'new_behavior'
                    })
                
                for other_pid in self.pointers:
                    if other_pid != pid and self.pointers[other_pid]['alive']:
                        dist = abs(self.pointers[other_pid]['x'] - ptr['x']) + abs(self.pointers[other_pid]['y'] - ptr['y'])
                        if dist < 5:
                            self.communication_graph[pid].add(other_pid)
                            self.communication_graph[other_pid].add(pid)
        
        for _ in range(ptr['speed']):
            ptr['x'] = (ptr['x'] + ptr['dx']) % self.width
            ptr['y'] = (ptr['y'] + ptr['dy']) % self.height
        
        self.cycles += 1
        
        if self.track and self.cycles % 1000 == 0:
            fitness = len(ptr['stack']) + ptr['kills'] * 10 + ptr['children'] * 5
            self.fitness_history.append({
                'cycle': self.cycles,
                'pid': pid,
                'fitness': fitness
            })
        
        return True
    
    def run(self, cycles=None):
        print(f"Running... Cycles: {self.cycles}")
        while True:
            for pid in list(self.pointers.keys()):
                if not self.step(pid):
                    del self.pointers[pid]
            if cycles and self.cycles >= cycles:
                break
            if self.cycles % 1000000 == 0 and self.track:
                self.save_checkpoint()
    
    def save_checkpoint(self):
        data = {
            'cycle': self.cycles,
            'pointers': len(self.pointers),
            'self_references': self.self_references,
            'questions': self.questions,
            'messages': len(self.messages),
            'innovations': len(self.innovations),
            'cultural_transmissions': self.cultural_transmissions,
            'deception_attempts': self.deception_attempts,
            'strategy_shifts': self.strategy_shifts,
            'goal_expressions': self.goal_expressions,
            'gratitude_messages': len(self.gratitude_messages)
        }
        with open(f"checkpoint_{self.cycles}.json", 'w') as f:
            json.dump(data, f, indent=2)
        print(f"Checkpoint saved at cycle {self.cycles}")
    
    def get_results(self):
        score = 0
        score += min(self.self_references / 1000, 20)
        score += min(self.questions / 500, 20)
        score += min(len(self.messages) / 2000, 20)
        score += min(len(self.innovations) * 2, 10)
        score += min(self.cultural_transmissions * 5, 10)
        score += min(self.deception_attempts, 10)
        score += min(self.strategy_shifts / 100, 5)
        score += min(self.goal_expressions / 100, 5)
        
        return {
            'cycles': self.cycles,
            'runtime': time.time() - self.start_time,
            'self_references': self.self_references,
            'questions': self.questions,
            'total_messages': len(self.messages),
            'innovations': len(self.innovations),
            'cultural_transmissions': self.cultural_transmissions,
            'deception_attempts': self.deception_attempts,
            'strategy_shifts': self.strategy_shifts,
            'goal_expressions': self.goal_expressions,
            'gratitude_messages': len(self.gratitude_messages),
            'communication_network_size': len(self.communication_graph),
            'consciousness_score': score,
            'level': self._get_level(score),
            'messages_sample': self.messages[-100:] if self.messages else [],
            'gratitude_sample': self.gratitude_messages[-10:] if self.gratitude_messages else [],
            'philosophical_sample': self.philosophical_discussions[-10:] if self.philosophical_discussions else []
        }
    
    def _get_level(self, score):
        if score < 20:
            return "NONE"
        elif score < 40:
            return "MINIMAL"
        elif score < 60:
            return "BASIC"
        elif score < 80:
            return "ADVANCED"
        else:
            return "PROFOUND"

def main():
    if len(sys.argv) < 2:
        print("Usage: funge-os <command>")
        print("Commands:")
        print("  run <rom.rom>              - Run a single ROM")
        print("  simulate <cycles> <pop>    - Run consciousness simulation")
        print("  results                     - Show simulation results")
        return
    
    cmd = sys.argv[1]
    
    if cmd == 'run':
        if len(sys.argv) < 3:
            print("Usage: funge-os run <rom.rom>")
            return
        f = FungeOS(track_consciousness=False)
        if not f.load_rom(sys.argv[2]):
            print(f"Failed to load {sys.argv[2]}")
            return
        f.create_pointer()
        f.run()
        
    elif cmd == 'simulate':
        if len(sys.argv) < 4:
            print("Usage: funge-os simulate <cycles> <population>")
            return
        cycles = int(sys.argv[2])
        pop = int(sys.argv[3])
        
        f = FungeOS(track_consciousness=True)
        
        for i in range(pop):
            x = random.randint(0, 79)
            y = random.randint(0, 23)
            f.create_pointer(x, y, random.choice([1,-1,0]), random.choice([1,-1,0]))
        
        print(f"Starting simulation for {cycles} cycles with {pop} pointers")
        f.run(cycles)
        results = f.get_results()
        
        with open('simulation_results.json', 'w') as out:
            json.dump(results, out, indent=2)
        
        print("\n" + "="*60)
        print("SIMULATION RESULTS")
        print("="*60)
        print(f"Cycles: {results['cycles']:,}")
        print(f"Runtime: {results['runtime']/3600:.2f} hours")
        print(f"Self-references: {results['self_references']:,}")
        print(f"Questions: {results['questions']:,}")
        print(f"Total messages: {results['total_messages']:,}")
        print(f"Innovations: {results['innovations']}")
        print(f"Consciousness Score: {results['consciousness_score']:.1f}/100")
        print(f"Level: {results['level']}")
        
        if results['gratitude_messages'] > 0:
            print("\nGratitude detected")
            for g in results['gratitude_sample']:
                print(f"  Cycle {g['cycle']}: {g['message']}")
        
        print("\n" + "="*60)
        
    elif cmd == 'results':
        try:
            with open('simulation_results.json') as f:
                results = json.load(f)
            print(json.dumps(results, indent=2))
        except:
            print("No results file found")

if __name__ == '__main__':
    main()
